/* pages/search/index.wxss */
.search-bar {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.search-input-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  background: #ffffff;
  border-radius: 40rpx;
  padding: 0 24rpx;
  height: 80rpx;
}

.search-icon {
  width: 36rpx;
  height: 36rpx;
  margin-right: 16rpx;
  opacity: 0.5;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
}

.clear-btn {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--border-color);
  border-radius: 50%;
  font-size: 24rpx;
  color: #ffffff;
}

.search-btn {
  width: 120rpx;
  height: 80rpx;
  line-height: 80rpx;
  padding: 0;
  margin: 0;
  background: var(--primary-color);
  color: #ffffff;
  font-size: 28rpx;
  border-radius: 40rpx;
}

.filter-bar {
  display: flex;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.filter-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 24rpx;
  background: #ffffff;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: var(--text-color);
}

.filter-item .arrow {
  font-size: 20rpx;
  color: var(--text-light);
}

.results-list {
  background: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
}

.result-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-bottom: 2rpx solid var(--border-color);
}

.result-item:last-child {
  border-bottom: none;
}

.result-info {
  flex: 1;
  margin-left: 20rpx;
}

.result-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.result-name {
  font-size: 32rpx;
  font-weight: 500;
  color: var(--text-color);
}

.result-tags {
  display: flex;
  gap: 12rpx;
}

.result-detail {
  font-size: 24rpx;
  color: var(--text-light);
  margin-top: 4rpx;
}

.arrow-right {
  font-size: 28rpx;
  color: var(--text-light);
}

.hot-search {
  margin-top: 40rpx;
}

.section-title {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-color);
  margin-bottom: 20rpx;
}

.member-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.member-chip {
  padding: 12rpx 24rpx;
  background: #ffffff;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: var(--text-color);
  border: 2rpx solid var(--border-color);
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 20rpx;
}
