/* pages/user/index.wxss */
.user-container {
  padding: 0;
  padding-bottom: 60rpx;
}

.user-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 30rpx;
  background: linear-gradient(135deg, var(--primary-color), var(--primary-light));
}

.user-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  margin-bottom: 20rpx;
}

.user-name {
  font-size: 40rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 12rpx;
}

.user-generation {
  padding: 6rpx 20rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 20rpx;
}

.user-generation text {
  font-size: 24rpx;
  color: #ffffff;
}

.register-tip {
  margin-top: 20rpx;
  text-align: center;
}

.register-tip text {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 16rpx;
}

.btn-small {
  width: 200rpx;
  height: 64rpx;
  line-height: 64rpx;
  font-size: 26rpx;
  padding: 0;
  margin: 0;
}

.menu-list {
  padding: 20rpx 0;
}

.menu-group {
  margin-bottom: 20rpx;
  background: #ffffff;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 2rpx solid var(--border-color);
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: #f5f5f5;
}

.menu-icon {
  width: 48rpx;
  height: 48rpx;
  margin-right: 20rpx;
  background: var(--secondary-color);
  border-radius: 12rpx;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: var(--text-color);
}

.arrow {
  font-size: 28rpx;
  color: var(--text-light);
}

.logout-btn {
  margin: 40rpx 30rpx;
  width: calc(100% - 60rpx);
}

.version-text {
  display: block;
  text-align: center;
  font-size: 24rpx;
  color: var(--text-light);
}
