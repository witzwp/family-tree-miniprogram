/* pages/statistics/index.wxss */

.stats-container {
  padding: 16rpx 24rpx 48rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* Loading */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #e0e0e0;
  border-top-color: #8b4513;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  margin-top: 16rpx;
  font-size: 28rpx;
  color: #999999;
}

/* Error */
.error-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}

.error-text {
  font-size: 28rpx;
  color: #e64340;
  margin-bottom: 24rpx;
}

.retry-btn {
  padding: 12rpx 32rpx;
  background-color: #8b4513;
  color: #ffffff;
  font-size: 28rpx;
  border-radius: 8rpx;
}

/* Summary Grid */
.summary-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.summary-card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.summary-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #8b4513;
  line-height: 1.2;
}

.summary-label {
  font-size: 24rpx;
  color: #999999;
  margin-top: 8rpx;
}

/* Card */
.card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 16rpx;
}

.card-note {
  font-size: 24rpx;
  color: #999999;
  margin-top: 8rpx;
  text-align: center;
}

.big-number {
  font-size: 72rpx;
  font-weight: bold;
  color: #8b4513;
  text-align: center;
  line-height: 1.2;
}

/* Charts */
.chart-wrap {
  width: 100%;
  height: 320rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.chart-canvas {
  width: 100%;
  height: 100%;
}

/* Timeline */
.timeline-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
}

.timeline-start,
.timeline-end {
  font-size: 28rpx;
  font-weight: 600;
  color: #8b4513;
  min-width: 80rpx;
  text-align: center;
}

.timeline-track {
  flex: 1;
  height: 16rpx;
  background-color: #e8e8e8;
  border-radius: 8rpx;
  margin: 0 16rpx;
  overflow: hidden;
}

.timeline-fill {
  height: 100%;
  background-color: #8b4513;
  border-radius: 8rpx;
}

.timeline-note {
  font-size: 24rpx;
  color: #999999;
  text-align: center;
  margin-top: 8rpx;
}

/* Surname List */
.surname-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.surname-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.surname-rank {
  width: 40rpx;
  height: 40rpx;
  border-radius: 20rpx;
  background-color: #f0f0f0;
  color: #666666;
  font-size: 22rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.surname-item:nth-child(1) .surname-rank {
  background-color: #ffd700;
  color: #8b4513;
}

.surname-item:nth-child(2) .surname-rank {
  background-color: #c0c0c0;
  color: #333333;
}

.surname-item:nth-child(3) .surname-rank {
  background-color: #cd7f32;
  color: #ffffff;
}

.surname-name {
  width: 80rpx;
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
}

.surname-bar-wrap {
  flex: 1;
  height: 20rpx;
  background-color: #f0f0f0;
  border-radius: 10rpx;
  overflow: hidden;
}

.surname-bar {
  height: 100%;
  background-color: #8b4513;
  border-radius: 10rpx;
}

.surname-count {
  width: 60rpx;
  font-size: 24rpx;
  color: #999999;
  text-align: right;
}
