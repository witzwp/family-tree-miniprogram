/* pages/register/relations.wxss */
.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--primary-color);
  margin-bottom: 24rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid var(--primary-color);
}

.selected-person {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
}

.person-name {
  flex: 1;
  margin-left: 16rpx;
  font-size: 30rpx;
  color: var(--text-color);
}

.remove-btn {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--error-color);
  color: #ffffff;
  border-radius: 50%;
  font-size: 28rpx;
}

.add-relation {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 30rpx;
  border: 4rpx dashed var(--border-color);
  border-radius: 12rpx;
  color: var(--text-light);
}

.add-icon {
  font-size: 40rpx;
  margin-right: 12rpx;
  color: var(--primary-color);
}

.children-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.child-item {
  flex: 1;
  min-width: 200rpx;
}

.skip-tip {
  text-align: center;
  margin: 30rpx 0;
}

.skip-tip text {
  font-size: 26rpx;
  color: var(--primary-color);
}

/* 弹窗样式 */
.selector-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.modal-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: #ffffff;
  border-radius: 24rpx 24rpx 0 0;
  max-height: 70vh;
  display: flex;
  flex-direction: column;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 2rpx solid var(--border-color);
  font-size: 32rpx;
  font-weight: bold;
}

.close-btn {
  font-size: 40rpx;
  color: var(--text-light);
}

.modal-body {
  flex: 1;
  overflow-y: auto;
  padding: 20rpx 30rpx 40rpx;
}

.modal-body .search-input {
  width: 100%;
  height: 80rpx;
  padding: 0 24rpx;
  border: 2rpx solid var(--border-color);
  border-radius: 40rpx;
  margin-bottom: 20rpx;
  box-sizing: border-box;
}

.member-option {
  display: flex;
  align-items: center;
  padding: 20rpx;
  border-bottom: 2rpx solid var(--border-color);
}

.generation-tag {
  margin-left: auto;
  font-size: 22rpx;
  color: var(--text-light);
  background: var(--secondary-color);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.add-new-btn {
  margin-top: 30rpx;
  padding: 24rpx;
  text-align: center;
  background: var(--primary-color);
  color: #ffffff;
  border-radius: 12rpx;
  font-size: 30rpx;
}
