/* pages/family/tree.wxss */
.tree-container {
  padding: 0;
  padding-bottom: 140rpx;
}

.stats-bar {
  display: flex;
  justify-content: space-around;
  padding: 30rpx;
  background: linear-gradient(135deg, var(--primary-color), var(--primary-light));
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #ffffff;
}

.stat-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 8rpx;
}

.view-switcher {
  display: flex;
  background: #ffffff;
  padding: 20rpx 30rpx;
  border-bottom: 2rpx solid var(--border-color);
}

.view-option {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: var(--text-light);
  border-bottom: 4rpx solid transparent;
}

.view-option.active {
  color: var(--primary-color);
  border-bottom-color: var(--primary-color);
}

.tree-view, .mindmap-view {
  height: calc(100vh - 240rpx);
}

.mindmap-canvas {
  width: 100%;
  height: 100%;
}

.list-view {
  padding: 20rpx 30rpx;
}

.generation-group {
  margin-bottom: 30rpx;
}

.generation-title {
  font-size: 28rpx;
  font-weight: bold;
  color: var(--primary-color);
  padding: 20rpx 0;
  border-bottom: 2rpx solid var(--border-color);
}

.member-list {
  background: #ffffff;
  border-radius: 12rpx;
  margin-top: 16rpx;
}

.member-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-bottom: 2rpx solid var(--border-color);
}

.member-item:last-child {
  border-bottom: none;
}

.member-info {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
}

.member-name {
  font-size: 30rpx;
  color: var(--text-color);
  font-weight: 500;
}

.member-location {
  font-size: 24rpx;
  color: var(--text-light);
  margin-top: 4rpx;
}

.member-tag {
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
}

.tag-male {
  background: rgba(59, 130, 246, 0.1);
  color: #3b82f6;
}

.tag-female {
  background: rgba(236, 72, 153, 0.1);
  color: #ec4899;
}

.fab-container {
  position: fixed;
  right: 30rpx;
  bottom: 150rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  z-index: 100;
}

.fab-btn {
  width: 90rpx;
  height: 90rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.2);
}

.fab-btn image {
  width: 40rpx;
  height: 40rpx;
}

.fab-search {
  background: #ffffff;
}

.fab-add {
  background: var(--primary-color);
}

.fab-add text {
  font-size: 48rpx;
  color: #ffffff;
  font-weight: 300;
}
