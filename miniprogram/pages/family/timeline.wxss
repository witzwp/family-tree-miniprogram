/* pages/family/timeline.wxss */
.timeline-container {
  padding: 0;
  display: flex;
  flex-direction: column;
  height: 100vh;
  box-sizing: border-box;
}

/* Loading and error states */
.loading-state,
.error-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 60rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid var(--border-color);
  border-top-color: var(--primary-color);
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  font-size: 28rpx;
  color: var(--text-light);
}

.error-text {
  font-size: 30rpx;
  color: var(--error-color);
  margin-bottom: 30rpx;
}

/* Timeline content */
.timeline-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  position: relative;
}

/* Zoom controls */
.zoom-controls {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  z-index: 100;
}

.zoom-btn {
  width: 64rpx;
  height: 64rpx;
  background: #ffffff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: bold;
  color: var(--primary-color);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.15);
}

.zoom-btn:active {
  opacity: 0.8;
}

/* Scrollable area */
.timeline-scroll {
  flex: 1;
  width: 100%;
  background: #ffffff;
}

.timeline-inner {
  min-height: 100%;
  padding: 80rpx 0 40rpx 0;
  box-sizing: border-box;
}

/* Year axis */
.year-axis {
  position: relative;
  height: 60rpx;
  margin-bottom: 20rpx;
  border-bottom: 2rpx solid var(--border-color);
}

.axis-line {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: var(--border-color);
}

.year-marker {
  position: absolute;
  bottom: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  transform: translateX(-50%);
}

.year-tick {
  width: 2rpx;
  height: 16rpx;
  background: var(--text-light);
}

.year-label {
  font-size: 22rpx;
  color: var(--text-light);
  margin-top: 4rpx;
  white-space: nowrap;
}

/* Generation section */
.generation-section {
  margin-bottom: 40rpx;
}

.generation-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 30rpx;
  background: linear-gradient(90deg, var(--secondary-color), transparent);
  border-left: 6rpx solid var(--primary-color);
  margin-bottom: 16rpx;
}

.generation-title {
  font-size: 28rpx;
  font-weight: bold;
  color: var(--primary-color);
}

.generation-era {
  font-size: 22rpx;
  color: var(--text-light);
  background: rgba(139, 69, 19, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

/* Member bars */
.member-bars {
  position: relative;
  padding: 10rpx 0;
  min-height: 80rpx;
}

.member-bar-wrapper {
  position: relative;
  height: 64rpx;
  margin-bottom: 48rpx;
}

.member-bar-wrapper:last-child {
  margin-bottom: 0;
}

.member-bar {
  position: absolute;
  top: 0;
  height: 48rpx;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  padding: 0 12rpx;
  box-sizing: border-box;
  min-width: 80rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  transition: all 0.2s;
}

.member-bar:active {
  opacity: 0.8;
  transform: scaleY(1.1);
}

.member-bar-name {
  font-size: 22rpx;
  color: #ffffff;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  font-weight: 500;
}

.member-info-bubble {
  position: absolute;
  top: 52rpx;
  display: flex;
  flex-direction: column;
  gap: 2rpx;
}

.member-age {
  font-size: 20rpx;
  color: var(--text-color);
  font-weight: 500;
}

.member-years {
  font-size: 18rpx;
  color: var(--text-light);
}
