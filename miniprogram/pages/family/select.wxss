/* pages/family/select.wxss */
.select-container {
  padding: 0;
  padding-bottom: 160rpx;
}

.current-family-bar {
  padding: 20rpx 30rpx;
  background: rgba(139, 69, 19, 0.05);
}

.current-label {
  font-size: 24rpx;
  color: var(--primary-color);
}

.family-list {
  padding: 20rpx 30rpx;
}

.family-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  border: 2rpx solid transparent;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.family-card.active {
  border-color: var(--primary-color);
  background: rgba(139, 69, 19, 0.02);
}

.family-card:active {
  opacity: 0.8;
}

.family-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.family-name {
  font-size: 34rpx;
  font-weight: bold;
  color: var(--text-color);
}

.active-badge {
  padding: 4rpx 16rpx;
  background: var(--primary-color);
  border-radius: 20rpx;
}

.active-badge text {
  font-size: 22rpx;
  color: #ffffff;
}

.family-desc {
  display: block;
  font-size: 26rpx;
  color: var(--text-light);
  margin-bottom: 16rpx;
  line-height: 1.4;
}

.family-meta {
  display: flex;
  gap: 24rpx;
}

.meta-item {
  font-size: 24rpx;
  color: var(--text-light);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 60rpx;
}

.empty-text {
  font-size: 30rpx;
  color: var(--text-light);
  margin-bottom: 12rpx;
}

.empty-sub {
  font-size: 26rpx;
  color: var(--text-light);
}

.loading-state {
  text-align: center;
  padding: 120rpx;
}

.loading-state text {
  font-size: 28rpx;
  color: var(--text-light);
}

.create-btn-wrapper {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 30rpx 40rpx;
  background: #ffffff;
  border-top: 2rpx solid var(--border-color);
}

.create-btn {
  width: 100%;
}

/* Modal */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 200;
}

.modal-content {
  position: fixed;
  left: 60rpx;
  right: 60rpx;
  top: 50%;
  transform: translateY(-50%);
  background: #ffffff;
  border-radius: 20rpx;
  z-index: 201;
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 2rpx solid var(--border-color);
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-color);
}

.modal-close {
  font-size: 40rpx;
  color: var(--text-light);
  padding: 0 10rpx;
}

.modal-body {
  padding: 30rpx;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: var(--text-color);
  margin-bottom: 12rpx;
}

.form-input {
  height: 80rpx;
  padding: 0 20rpx;
  border: 2rpx solid var(--border-color);
  border-radius: 12rpx;
  font-size: 28rpx;
  background: #fafafa;
}

.modal-footer {
  display: flex;
  padding: 20rpx 30rpx 30rpx;
  gap: 20rpx;
}

.modal-btn {
  flex: 1;
}
