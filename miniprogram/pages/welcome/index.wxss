/* pages/welcome/index.wxss */
.welcome-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 60rpx;
  background: linear-gradient(180deg, #fff8f0 0%, #ffffff 100%);
}

.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
}

.logo {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
}

.title {
  font-size: 56rpx;
  font-weight: bold;
  color: var(--primary-color);
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 28rpx;
  color: var(--text-light);
}

.features-section {
  display: flex;
  justify-content: space-around;
  width: 100%;
  margin-bottom: 100rpx;
}

.feature-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.feature-icon {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 16rpx;
  background: var(--secondary-color);
  border-radius: 20rpx;
}

.feature-text {
  font-size: 24rpx;
  color: var(--text-color);
}

.action-section {
  width: 100%;
}

.action-section .btn {
  margin-bottom: 20rpx;
}

.tip-text {
  display: block;
  text-align: center;
  font-size: 24rpx;
  color: var(--text-light);
}
