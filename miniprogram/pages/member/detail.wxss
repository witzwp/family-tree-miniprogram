/* pages/member/detail.wxss */
.detail-container {
  padding-bottom: 40rpx;
}

.header-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 30rpx;
  background: linear-gradient(135deg, var(--primary-color), var(--primary-light));
  border-radius: 0 0 32rpx 32rpx;
  margin: -30rpx -30rpx 30rpx;
}

.detail-avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 6rpx solid rgba(255, 255, 255, 0.3);
  margin-bottom: 20rpx;
}

.detail-name {
  font-size: 44rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 16rpx;
}

.detail-tags {
  display: flex;
  gap: 16rpx;
}

.detail-tags .tag {
  background: rgba(255, 255, 255, 0.2);
  color: #ffffff;
}

.edit-btn {
  margin-top: 20rpx;
  padding: 12rpx 32rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 30rpx;
}

.edit-btn text {
  font-size: 26rpx;
  color: #ffffff;
}

.info-card, .relations-card {
  margin-bottom: 20rpx;
}

.info-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-color);
  margin-bottom: 24rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid var(--primary-color);
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 2rpx solid var(--border-color);
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: var(--text-light);
}

.info-value {
  font-size: 28rpx;
  color: var(--text-color);
}

.copy-btn {
  margin-left: 16rpx;
  padding: 4rpx 16rpx;
  background: var(--primary-color);
  color: #ffffff;
  border-radius: 8rpx;
  font-size: 22rpx;
}

.bio-section {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 2rpx solid var(--border-color);
}

.bio-text {
  display: block;
  margin-top: 12rpx;
  font-size: 28rpx;
  color: var(--text-color);
  line-height: 1.6;
}

.relation-section {
  margin-bottom: 30rpx;
}

.relation-section:last-child {
  margin-bottom: 0;
}

.relation-title {
  display: block;
  font-size: 28rpx;
  color: var(--text-light);
  margin-bottom: 16rpx;
}

.relation-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.relation-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
}

.relation-info {
  flex: 1;
  margin-left: 16rpx;
}

.relation-name {
  display: block;
  font-size: 30rpx;
  color: var(--text-color);
  font-weight: 500;
}

.relation-type {
  font-size: 24rpx;
  color: var(--text-light);
  margin-top: 4rpx;
}

.relation-item .arrow {
  color: var(--text-light);
}

.empty-text {
  padding: 30rpx;
  text-align: center;
  color: var(--text-light);
  font-size: 26rpx;
}
