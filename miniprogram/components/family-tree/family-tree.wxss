/* components/family-tree/family-tree.wxss */
.family-tree-container {
  width: 100%;
  height: 100%;
  position: relative;
  background: #fafafa;
}

.tree-scroll {
  width: 100%;
  height: 100%;
}

.tree-content {
  position: relative;
  min-width: 100%;
  min-height: 100%;
}

.tree-node {
  position: absolute;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  background: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
  min-width: 160rpx;
  transform: translate(-50%, 0);
}

.node-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-bottom: 12rpx;
  border: 4rpx solid var(--secondary-color);
}

.node-name {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--text-color);
  max-width: 160rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.node-generation {
  font-size: 20rpx;
  color: var(--primary-color);
  background: rgba(139, 69, 19, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-top: 8rpx;
}

.lines-canvas {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
}

.tree-controls {
  position: absolute;
  right: 30rpx;
  bottom: 30rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.control-btn {
  width: 70rpx;
  height: 70rpx;
  border-radius: 50%;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: var(--primary-color);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
}

.control-btn:active {
  opacity: 0.8;
}
